---
import type { homeContent } from "../config/home";
import FeaturedCard from "./FeaturedCard.astro";

interface Props {
    featured: typeof homeContent.featured;
}

const { featured } = Astro.props;
---

<!-- Alternate background for visual rhythm -->
<section
    class="bg-section-alt py-16 md:py-20"
    aria-labelledby="featured-heading"
>
    <div class="max-w-5xl mx-auto px-6">
        <!-- Section header -->
        <div class="flex flex-col sm:flex-row sm:items-end gap-3 mb-10">
            <div class="sm:w-3/4">
                <!-- Manrope 24/30px / bold / UPPERCASE / -0.02em -->
                <h2
                    id="featured-heading"
                    class="font-heading text-2xl md:text-[1.875rem] font-bold tracking-[-0.02em] leading-[1.2] text-text-primary uppercase"
                >
                    <span class="text-accent-soft font-extrabold">/</span>
                    {featured.title}
                </h2>
                <!-- Inter 16px / normal -->
                <p class="text-base text-text-secondary mt-2 leading-[1.65]">
                    {featured.description}
                </p>
            </div>
            <!-- Inter 14px / medium -->
            <a
                href={featured.articlesHref}
                class="sm:w-1/4 sm:text-right text-sm font-medium text-accent hover:opacity-75 transition-opacity"
            >
                {featured.articlesLinkLabel} →
            </a>
        </div>

        <!-- Cards grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
            {featured.items.map((item) => <FeaturedCard {...item} />)}
        </div>
    </div>
</section>
