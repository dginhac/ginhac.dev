---
import { site } from "../config/site";
import { mainNav } from "../config/navigation";

const logoGlob = import.meta.glob<string>("../assets/*.svg", { query: "?raw", import: "default" });
const logoRaw: string = (await logoGlob[site.logo.src]?.()) ?? "";
---

<header id="site-header" aria-label="Site header">
  <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between gap-6">
    <a href="/" class="site-name flex items-center gap-2.5 text-sm font-semibold tracking-tight transition-colors">
      <span class="logo-mark" aria-hidden="true" style={`--logo-h: ${site.logo.height}px`} set:html={logoRaw} />
      {site.name}
    </a>

    <!-- Desktop nav -->
    <nav class="hidden sm:block" aria-label="Main navigation">
      <ul class="flex items-center gap-1">
        {
          mainNav.map((item) => (
            <li>
              <a href={item.href} class="nav-link px-3 py-1.5 text-sm rounded-md transition-colors">
                {item.label}
              </a>
            </li>
          ))
        }
        <li class="ml-3 pl-3 lang-divider border-l transition-colors">
          <a
            href="/fr/"
            class="lang-link px-2 py-1 text-xs font-medium uppercase tracking-widest transition-colors rounded"
            lang="fr"
            hreflang="fr"
            aria-label="Version française"
          >
            FR
          </a>
        </li>
      </ul>
    </nav>

    <!-- Hamburger button (mobile only) -->
    <button
      id="menu-toggle"
      class="sm:hidden menu-btn flex items-center justify-center w-9 h-9 rounded-md transition-colors"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open navigation"
    >
      <svg class="icon-open" width="18" height="14" viewBox="0 0 18 14" fill="none" aria-hidden="true">
        <rect y="0" width="18" height="2" rx="1" fill="currentColor"/>
        <rect y="6" width="18" height="2" rx="1" fill="currentColor"/>
        <rect y="12" width="18" height="2" rx="1" fill="currentColor"/>
      </svg>
      <svg class="icon-close" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Mobile dropdown -->
  <div id="mobile-menu" class="mobile-menu border-t" aria-hidden="true">
    <nav class="max-w-5xl mx-auto px-6 py-3" aria-label="Mobile navigation">
      <ul class="flex flex-col gap-0.5">
        {
          mainNav.map((item) => (
            <li>
              <a href={item.href} class="nav-link block px-3 py-2.5 text-sm rounded-md transition-colors">
                {item.label}
              </a>
            </li>
          ))
        }
        <li class="mt-2 pt-2 border-t lang-divider">
          <a
            href="/fr/"
            class="lang-link block px-3 py-2.5 text-xs font-medium uppercase tracking-widest rounded transition-colors"
            lang="fr"
            hreflang="fr"
            aria-label="Version française"
          >
            FR
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  #site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background-color: transparent;
    border-bottom: 1px solid transparent;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease;

    --hdr-name:       #0F172A;
    --hdr-link:       #4B5563;
    --hdr-link-hover: rgba(15, 23, 42, 0.05);
    --hdr-fr:         #9CA3AF;
    --hdr-divider:    #E5EAF0;
  }

  #site-header.is-scrolled,
  #site-header.menu-open {
    background-color: #FFFFFF;
    border-bottom-color: #E5EAF0;
    --hdr-link-hover: #F3F6FA;
  }

  .logo-mark :global(svg) {
    height: var(--logo-h);
    width: auto;
    display: block;
  }

  .site-name { color: var(--hdr-name); }
  .site-name:hover { color: var(--hdr-name); opacity: 0.65; }

  .nav-link { color: var(--hdr-link); }
  .nav-link:hover { background-color: var(--hdr-link-hover); color: var(--hdr-name); }

  .lang-link { color: var(--hdr-fr); }
  .lang-link:hover { color: var(--hdr-link); }

  .lang-divider { border-color: var(--hdr-divider); }

  /* Hamburger button */
  .menu-btn { color: var(--hdr-link); }
  .menu-btn:hover { background-color: var(--hdr-link-hover); color: var(--hdr-name); }

  /* Mobile menu: hidden by default, shown via .menu-open */
  .mobile-menu {
    display: none;
    background-color: #FFFFFF;
    border-color: #E5EAF0;
  }

  #site-header.menu-open .mobile-menu {
    display: block;
  }

  /* Icon swap */
  .icon-close { display: none; }
  #site-header.menu-open .icon-open { display: none; }
  #site-header.menu-open .icon-close { display: block; }
</style>

<script>
  const header = document.getElementById("site-header");
  const toggle = document.getElementById("menu-toggle");

  // Scroll handler
  const updateScroll = () => {
    header?.classList.toggle("is-scrolled", window.scrollY > 40);
  };
  window.addEventListener("scroll", updateScroll, { passive: true });
  updateScroll();

  // Hamburger toggle
  toggle?.addEventListener("click", () => {
    const open = header?.classList.toggle("menu-open");
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close navigation" : "Open navigation");
    document.getElementById("mobile-menu")?.setAttribute("aria-hidden", String(!open));
  });
</script>
