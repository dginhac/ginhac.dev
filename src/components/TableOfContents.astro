---
import type { MarkdownHeading } from "astro";

interface Props {
    headings: MarkdownHeading[];
}

const { headings } = Astro.props;

const END_SECTIONS = new Set([
    "resources",
    "bibliography",
    "references",
    "related posts",
    "further reading",
    "notes",
    "see also",
]);

const firstEndIdx = headings.findIndex((h) =>
    END_SECTIONS.has(h.text.toLowerCase())
);
---

<nav
    aria-label="Table of contents"
    class="sticky top-[5.5rem] max-h-[calc(100vh-7rem)] overflow-y-auto pl-4 border-l border-border"
>
    <p class="text-[0.6875rem] font-semibold tracking-[0.08em] uppercase text-text-secondary opacity-[0.55] mb-3.5">
        Contents
    </p>
    <a
        href="#top"
        class="block text-[0.8125rem] text-text-secondary no-underline opacity-[0.55] transition-[color,opacity] duration-150 mb-[0.625rem] hover:text-accent hover:opacity-100"
    >
        ↑ Top
    </a>
    <hr class="border-0 border-t border-border mb-3" />
    <ul class="list-none p-0 m-0 flex flex-col gap-0.5">
        {
            headings.map((h, i) => (
                <Fragment>
                    {i === firstEndIdx && firstEndIdx > 0 && (
                        <li aria-hidden="true" class="list-none py-1.5">
                            <hr class="border-0 border-t border-border" />
                        </li>
                    )}
                    <li>
                        <a
                            href={`#${h.slug}`}
                            class:list={[
                                "block text-[0.8125rem] leading-[1.5] text-text-secondary no-underline py-1 opacity-[0.7] transition-[color,opacity] duration-150 hover:text-accent hover:opacity-100 [&.is-active]:text-accent [&.is-active]:opacity-100",
                                { "pl-[0.875rem]": h.depth === 3 },
                            ]}
                            data-toc-heading={h.slug}
                        >
                            {h.text}
                        </a>
                    </li>
                </Fragment>
            ))
        }
    </ul>
</nav>

<script>
    function initToc() {
        const links =
            document.querySelectorAll<HTMLAnchorElement>("[data-toc-heading]");
        if (!links.length) return;

        const headingEls = Array.from(links)
            .map((l) => document.getElementById(l.dataset.tocHeading!))
            .filter(Boolean) as HTMLElement[];

        let activeId = "";

        function setActive(id: string) {
            if (id === activeId) return;
            activeId = id;
            links.forEach((l) =>
                l.classList.toggle(
                    "is-active",
                    l.dataset.tocHeading === id
                )
            );
        }

        function onScroll() {
            const scrollY = window.scrollY + 120;
            let current = headingEls[0]?.id ?? "";
            for (const el of headingEls) {
                if (el.offsetTop <= scrollY) current = el.id;
            }
            setActive(current);
        }

        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
    }

    initToc();
    document.addEventListener("astro:page-load", initToc);
</script>
