---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  align?: 'left' | 'right' | 'center' | 'full';
  width?: 'third' | 'half' | 'two-thirds' | 'full';
}

const { src, alt, caption, align = 'center', width = 'full' } = Astro.props;

const mdWidth: Record<string, string> = {
  third: 'md:w-1/3',
  half: 'md:w-1/2',
  'two-thirds': 'md:w-2/3',
  full: '',
};
const mw = mdWidth[width] ?? 'md:w-1/3';

const figClass =
  align === 'right' ? `w-full mb-6 md:mb-2 md:float-right md:ml-8 ${mw}` :
  align === 'left'  ? `w-full mb-6 md:mb-2 md:float-left md:mr-8 ${mw}` :
  align === 'full'  ? 'w-full my-10 clear-both' :
  /* center */        `mx-auto my-8 ${mw}`.trim();
---

<figure class={figClass}>
  <img
    src={src}
    alt={alt}
    class="w-full rounded object-cover"
    loading="lazy"
  />
  {caption && (
    <figcaption class="mt-2.5 text-sm leading-snug italic" style="color: var(--color-text-secondary);">
      {caption}
    </figcaption>
  )}
</figure>
