---
interface Props {
  title: string;
  description?: string;
  href: string;
  period?: string;
  funding?: string;
  role?: string;
  level?: string;
  institution?: string;
  volume?: string;
  tags?: string[];
  linkLabel?: string;
}

const {
  title,
  description,
  href,
  period,
  funding,
  role,
  level,
  institution,
  volume,
  tags = [],
  linkLabel = "View →",
} = Astro.props;

const join = (items: Array<string | undefined>) =>
  items.filter(Boolean).join(" · ");

const line1 = join([period, funding ?? level]);
const line2 = join([institution, volume]);
const line3 = role;

const hasMetadata = !!(line1 || line2 || line3);
---

<a
  href={href}
  class="group flex flex-col bg-white rounded-lg border border-border hover:bg-section-alt transition-colors p-4"
>
  <h3
    class="font-heading text-sm font-semibold tracking-[-0.01em] text-text-primary leading-[1.3] mb-1.5 group-hover:text-accent transition-colors"
  >
    {title}
  </h3>

  {
    hasMetadata && (
      <div class="mb-2 space-y-0.5">
        {line1 && <p class="text-xs text-text-secondary">{line1}</p>}
        {line2 && <p class="text-xs text-text-secondary">{line2}</p>}
        {line3 && <p class="text-xs text-text-secondary">{line3}</p>}
      </div>
    )
  }

  {
    description && (
      <p class="text-sm text-text-secondary leading-[1.6] line-clamp-2 flex-1">
        {description}
      </p>
    )
  }

  {
    tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-2.5">
        {tags.map((tag) => (
          <span class="text-xs text-text-secondary bg-section-alt border border-border rounded px-1.5 py-0.5">
            {tag}
          </span>
        ))}
      </div>
    )
  }

  <span
    class="mt-3 text-xs font-medium text-text-secondary group-hover:text-accent transition-colors"
    aria-hidden="true"
  >
    {linkLabel}
  </span>
</a>
