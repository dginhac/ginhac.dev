---
interface Props {
  title: string;
  description?: string;
  href: string;
  tags?: string[];
  linkLabel?: string;
}

const {
  title,
  description,
  href,
  tags = [],
  linkLabel = "View →",
} = Astro.props;
---

<a
  href={href}
  class="group flex flex-col bg-white rounded-lg border border-border hover:bg-section-alt transition-colors p-4"
>
  <h3
    class="font-heading text-sm font-semibold tracking-[-0.01em] text-text-primary leading-[1.3] mb-1.5 group-hover:text-accent transition-colors"
  >
    {title}
  </h3>

  {
    description && (
      <p class="text-sm text-text-secondary leading-[1.6] line-clamp-2 flex-1">
        {description}
      </p>
    )
  }

  {
    tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-2.5">
        {tags.map((tag) => (
          <span class="text-xs text-text-secondary bg-section-alt border border-border rounded px-1.5 py-0.5">
            {tag}
          </span>
        ))}
      </div>
    )
  }

  <span
    class="mt-3 text-xs font-medium text-text-secondary group-hover:text-accent transition-colors"
    aria-hidden="true"
  >
    {linkLabel}
  </span>
</a>
