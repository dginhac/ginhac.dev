---
import type { homeContent } from "../../config/content/home";
import { renderMarkdown } from "../../utils/markdown";
import ButtonLink from "../ui/ButtonLink.astro";
import Link from "../ui/Link.astro";
import Eyebrow from "../ui/Eyebrow.astro";

interface Props {
    bio: typeof homeContent.bio;
}

const { bio } = Astro.props;
---

<!-- Main site background — seamless with body -->
<section class="bg-site-bg py-16 md:py-20" aria-labelledby="bio-heading">
    <div class="max-w-5xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            <!-- Profile text — spans 2 of 3 columns -->
            <div class="md:col-span-2">
                <!-- Eyebrow -->
                <Eyebrow class="mb-2">{bio.eyebrow}</Eyebrow>
                <!-- Manrope 24/30px / bold / UPPERCASE / -0.02em -->
                <h2
                    id="bio-heading"
                    class="font-heading text-2xl md:text-[1.875rem] font-bold tracking-[-0.02em] leading-[1.2] text-text-primary uppercase mb-5"
                >
                    <span class="text-accent-soft font-extrabold">/</span>
                    {bio.title}
                </h2>
                <!-- Inter 16px / normal / 1.7 -->
                <div
                    class="text-base text-text-secondary leading-[1.7] mb-7"
                    set:html={renderMarkdown(bio.text)}
                />
                <!-- Action links -->
                {
                    bio.links.length > 0 && (
                        <div class="flex flex-wrap gap-3">
                            {bio.links.map((link) => (
                                <ButtonLink
                                    href={link.href}
                                    variant={link.variant}
                                    external={link.external}
                                    download={link.download}
                                >
                                    {link.label}
                                </ButtonLink>
                            ))}
                        </div>
                    )
                }
            </div>

            <!-- Currently -->
            <div>
                <!-- Inter 13px / medium / 0.08em / uppercase -->
                <p
                    class="text-[13px] font-medium uppercase tracking-[0.08em] text-text-secondary mb-4"
                >
                    {bio.currentTitle}
                </p>
                <!-- Inter 14px / normal / 1.65 -->
                <p class="text-sm text-text-secondary leading-[1.65] mb-5">
                    {bio.currentIntro}
                </p>
                <ul class="space-y-3">
                    {
                        bio.currentItems.map((item) => (
                            <li class="flex gap-3 text-sm text-text-secondary leading-[1.65]">
                                <span
                                    class="mt-2 shrink-0 w-1.5 h-1.5 rounded-full bg-accent"
                                    aria-hidden="true"
                                />
                                <span>
                                    {item.parts.map((part) =>
                                        typeof part === "string" ? (
                                            part
                                        ) : (
                                            <Link
                                                href={part.href}
                                                arrow="none"
                                                external={part.external}
                                            >
                                                {part.label}
                                            </Link>
                                        ),
                                    )}
                                </span>
                            </li>
                        ))
                    }
                </ul>
            </div>
        </div>
    </div>
</section>
