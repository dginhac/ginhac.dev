---
import type { homeContent } from "../../config/content/home";
import { Image } from "astro:assets";
import ButtonLink from "../ui/ButtonLink.astro";
import Eyebrow from "../ui/Eyebrow.astro";

interface Props {
    hero: typeof homeContent.hero;
}

const { hero } = Astro.props;
---

<!--
  Light hero. pt-28/pt-36 absorbs the fixed header height.
  border-b creates a gentle boundary toward the Featured section.
-->
<section
    class="bg-hero-bg border-b border-border pt-28 pb-20 md:pt-36 md:pb-28"
>
    <div class="max-w-5xl mx-auto px-6">
        <div
            class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-16 items-center"
        >
            <!-- Text column -->
            <div class="order-2 md:order-1 md:col-span-2">
                <!-- Eyebrow -->
                <Eyebrow>{hero.eyebrow}</Eyebrow>

                <!--
                  Manrope heading. Base weight is font-light.
                  tracking-[-0.03em] and leading-[1.07] per typographic spec.
                -->
                <h1
                    class="font-heading text-3xl md:text-[2.5rem] font-bold tracking-[-0.02em] text-hero-text leading-[1.2] mb-6"
                >
                    <span class="text-accent-soft font-extrabold">/</span>
                    {hero.title}
                </h1>

                <!-- Subtitle: Inter 16/18px / normal / 1.65 -->
                <p
                    class="text-base md:text-lg text-hero-muted leading-[1.65] mb-10 max-w-prose"
                >
                    {hero.subtitle}
                </p>

                <!-- CTAs -->
                {
                    hero.links.length > 0 && (
                        <div class="flex flex-wrap items-center gap-3">
                            {hero.links.map((link) => (
                                <ButtonLink
                                    href={link.href}
                                    variant={link.variant}
                                    external={link.external}
                                    download={link.download}
                                >
                                    {link.label}
                                </ButtonLink>
                            ))}
                        </div>
                    )
                }
            </div>

            <!-- Portrait column -->
            <div class="order-1 md:order-2 flex justify-center md:justify-end">
                <div class="relative w-60 h-72 md:w-68 md:h-[20rem]">
                    <!-- Soft accent dot — decorative only -->
                    <!--
                    <div
                        class="absolute z-11 -top-1.5 -right-1.5 w-5 h-5 rounded-full bg-accent-soft"
                        aria-hidden="true"
                    >
                    </div>
                    -->
                    <!-- Portrait -->
                    <Image
                        src={hero.portrait}
                        alt={hero.portraitAlt}
                        loading="eager"
                        fetchpriority="high"
                        decoding="async"
                        class="relative z-10 w-full h-full object-cover"
                    />
                </div>
            </div>
        </div>
    </div>
</section>
