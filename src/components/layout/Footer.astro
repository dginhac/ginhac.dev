---
import { site } from "../../config/content/site";
import { mainNav } from "../../config/navigation";
import { links } from "../../config/links";
import { Coffee } from "@lucide/astro";
import Link from "../ui/Link.astro";

const externalLinks = [
    links.scholar,
    links.github,
    links.linkedin,
    links.orcid,
];
---

<!-- footer-bg (#EEF3F8) is one step deeper than section-alt (#F3F6FA) -->
<footer class="bg-footer-bg border-t border-border">
    <div class="max-w-5xl mx-auto px-6 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">
            <!-- Identity -->
            <div>
                <p class="text-sm font-semibold text-text-primary">
                    {site.name}
                </p>
                <p class="text-xs text-text-secondary mt-1 leading-relaxed">
                    {site.title}
                </p>
                <p
                    class="text-xs text-text-secondary mt-5 font-mono select-all opacity-60"
                >
                    {links.email}
                </p>
            </div>

            <!-- Navigation -->
            <div>
                <p
                    class="text-xs font-semibold uppercase tracking-widest text-text-secondary opacity-50 mb-3"
                >
                    Navigation
                </p>
                <ul class="space-y-2">
                    {
                        mainNav.map((item) => (
                            <li>
                                <Link
                                    href={item.href}
                                    class="text-sm text-text-secondary hover:text-text-primary"
                                >
                                    {item.label}
                                </Link>
                            </li>
                        ))
                    }
                </ul>
            </div>

            <!-- Profiles -->
            <div>
                <p
                    class="text-xs font-semibold uppercase tracking-widest text-text-secondary opacity-50 mb-3"
                >
                    Profiles
                </p>
                <ul class="space-y-2">
                    {
                        externalLinks.map((item) => (
                            <li>
                                <Link
                                    href={item.href}
                                    class="text-sm text-text-secondary hover:text-text-primary"
                                >
                                    {item.label}
                                </Link>
                            </li>
                        ))
                    }
                </ul>
            </div>
        </div>

        <!-- Bottom bar -->
        <div
            class="border-t border-border pt-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 text-xs text-text-secondary opacity-50"
        >
            <p>
                &copy; 2026 {site.name} · Built with{" "}
                <Link href="https://astro.build"> Astro </Link>
                {", "}
                <Link href="https://claude.com"> Claude Code </Link>
                {" and a lot of "}
                <Coffee size={16} class="inline-block align-middle" />
                . Source code on <Link
                    href="https://github.com/dginhac/ginhac.dev"
                >
                    GitHub
                </Link>
                .
            </p>
            <p>
                <Link href="/legal" class="text-text-secondary font-medium"
                    >Legal notice</Link
                >
            </p>
        </div>
    </div>
</footer>
