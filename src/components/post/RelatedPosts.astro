---
import type { CollectionEntry } from "astro:content";
import TypeBadge from "../TypeBadge.astro";

interface Props {
    posts: CollectionEntry<"posts">[];
}

const { posts } = Astro.props;
---

{
    posts.length > 0 && (
        <section id="related-posts" class="mt-16 pt-7 border-t border-border">
            <h2 class="font-heading text-[1.375rem] font-bold tracking-[-0.02em] leading-[1.25] text-hero-text mb-3.5">
                Related posts
            </h2>
            <ul class="list-none p-0 m-0 flex flex-col">
                {posts.map((post) => (
                    <li>
                        <a
                            href={`/posts/${post.id}/`}
                            class="block py-4 border-b border-border no-underline transition-opacity hover:opacity-75"
                        >
                            {post.data.type && (
                                <div class="mb-2">
                                    <TypeBadge type={post.data.type.toUpperCase()} />
                                </div>
                            )}
                            <p class="font-heading text-[0.9375rem] font-semibold tracking-[-0.01em] leading-[1.3] text-text-primary mb-1.5">
                                {post.data.title}
                            </p>
                            {post.data.description && (
                                <p class="text-[0.8125rem] leading-[1.55] text-text-secondary m-0 line-clamp-2">
                                    {post.data.description}
                                </p>
                            )}
                        </a>
                    </li>
                ))}
            </ul>
        </section>
    )
}
