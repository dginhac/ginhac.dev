---
import { Github, Google, Orcid, Zenodo, Arxiv } from "simple-icons-astro";

import {
    Database,
    FileText,
    Download,
    Link,
    ExternalLink,
    FileCode,
    BookOpen,
    FlaskConical,
    GraduationCap,
} from "@lucide/astro";

const iconMap = {
    github: Github,
    google: Google,
    orcid: Orcid,
    zenodo: Zenodo,
    arxiv: Arxiv,

    database: Database,
    file: FileText,
    download: Download,
    link: Link,
    external_link: ExternalLink,
    code: FileCode,
    publication: BookOpen,
    research: FlaskConical,
    teaching: GraduationCap,
};

const getIcon = (icon?: string) => {
    return icon && icon in iconMap
        ? iconMap[icon as keyof typeof iconMap]
        : Link;
};

const ExternalLinkIcon = getIcon("external_link");

interface ResourceItem {
    label: string;
    href: string;
    description?: string;
    icon?: string;
}

interface Props {
    items: ResourceItem[];
}

const { items } = Astro.props;

function isExternal(href: string) {
    return href.startsWith("http://") || href.startsWith("https://");
}
---

{
    items.length > 0 && (
        <section id="resources" class="mt-16 pt-7 border-t border-border">
            <h2 class="font-heading text-[1.375rem] font-bold tracking-[-0.02em] leading-[1.25] text-hero-text mb-4">
                Resources
            </h2>
            <ul class="list-none p-0 m-0 rounded-lg border border-border overflow-hidden">
                {items.map((item) => {
                    const external = isExternal(item.href);
                    const Icon = getIcon(item.icon);
                    return (
                        <li class="flex items-start gap-3 px-4 py-2 bg-white transition-colors hover:bg-section-alt border-b border-border last:border-b-0">
                            <Icon
                                size={15}
                                fill="currentColor"
                                aria-hidden="true"
                                class="flex-shrink-0 mt-1 text-text-secondary opacity-50"
                            />
                            <div>
                                <a
                                    href={item.href}
                                    target={external ? "_blank" : undefined}
                                    rel={
                                        external
                                            ? "noopener noreferrer"
                                            : undefined
                                    }
                                    class="inline-flex items-center gap-1 text-sm font-medium text-accent no-underline hover:underline hover:underline-offset-[3px]"
                                >
                                    {item.label}
                                    {external && (
                                        <ExternalLinkIcon
                                            size={11}
                                            aria-hidden="true"
                                            class="flex-shrink-0 opacity-60"
                                        />
                                    )}
                                </a>
                                {item.description && (
                                    <p class="text-xs leading-relaxed text-text-secondary mt-0.5 mb-0">
                                        {item.description}
                                    </p>
                                )}
                            </div>
                        </li>
                    );
                })}
            </ul>
        </section>
    )
}
