---
interface ResourceItem {
    label: string;
    href: string;
    description?: string;
}

interface Props {
    items: ResourceItem[];
}

const { items } = Astro.props;

function isExternal(href: string) {
    return href.startsWith("http://") || href.startsWith("https://");
}
---

<ul class="my-8">
    {
        items.map((item) => {
            const external = isExternal(item.href);
            return (
                <li class="py-4 first:pt-0 border-b border-border">
                    <a
                        href={item.href}
                        target={external ? "_blank" : undefined}
                        rel={external ? "noopener noreferrer" : undefined}
                        class="inline-flex items-baseline gap-1.5 font-semibold text-[0.9375rem] leading-snug mb-1 text-accent hover:underline hover:decoration-accent hover:underline-offset-[3px]"
                    >
                        {item.label}
                        {external && (
                            <span
                                aria-hidden="true"
                                class="text-[0.7rem] translate-y-[-1px] opacity-70"
                            >
                                ↗
                            </span>
                        )}
                    </a>
                    {item.description && (
                        <p class="text-sm leading-relaxed text-text-secondary mb-0">
                            {item.description}
                        </p>
                    )}
                </li>
            );
        })
    }
</ul>
