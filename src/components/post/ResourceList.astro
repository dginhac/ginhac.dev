---
import { icons } from "@lucide/astro";

interface ResourceItem {
    label: string;
    href: string;
    description?: string;
    icon?: string;
}

interface Props {
    items: ResourceItem[];
}

const { items } = Astro.props;

function isExternal(href: string) {
    return href.startsWith("http://") || href.startsWith("https://");
}

const iconMap: Record<string, keyof typeof icons> = {
    github: "GitBranch",
    database: "Database",
    file: "FileText",
    paper: "FileText",
    code: "Code",
    video: "Video",
    slides: "Presentation",
    download: "Download",
    link: "Link",
};

function getIconName(name?: string): keyof typeof icons {
    if (!name || !(name in iconMap)) return "Link";
    return iconMap[name];
}

const ExternalLinkIcon = icons["ExternalLink"];
---

{
    items.length > 0 && (
        <section id="resources" class="mt-16 pt-7 border-t border-border">
            <h2 class="font-heading text-[1.375rem] font-bold tracking-[-0.02em] leading-[1.25] text-hero-text mb-4">
                Resources
            </h2>
            <ul class="list-none p-0 m-0 rounded-lg border border-border overflow-hidden">
                {items.map((item) => {
                    const external = isExternal(item.href);
                    const Icon = icons[getIconName(item.icon)];
                    return (
                        <li class="flex items-start gap-3 px-4 py-2 bg-white transition-colors hover:bg-section-alt  border-border last:border-b-0">
                            <Icon
                                size={15}
                                aria-hidden="true"
                                class="flex-shrink-0 mt-1 text-text-secondary opacity-50"
                            />
                            <div>
                                <a
                                    href={item.href}
                                    target={external ? "_blank" : undefined}
                                    rel={
                                        external
                                            ? "noopener noreferrer"
                                            : undefined
                                    }
                                    class="inline-flex items-center gap-1 text-sm font-medium text-accent no-underline hover:underline hover:underline-offset-[3px]"
                                >
                                    {item.label}
                                    {external && (
                                        <ExternalLinkIcon
                                            size={11}
                                            aria-hidden="true"
                                            class="flex-shrink-0 opacity-60"
                                        />
                                    )}
                                </a>
                                {item.description && (
                                    <p class="text-xs leading-relaxed text-text-secondary mt-0.5 mb-0">
                                        {item.description}
                                    </p>
                                )}
                            </div>
                        </li>
                    );
                })}
            </ul>
        </section>
    )
}
