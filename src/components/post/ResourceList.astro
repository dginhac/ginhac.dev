---
import { Icon } from "astro-icon/components";

interface ResourceItem {
    label: string;
    href: string;
    description?: string;
    icon?: string;
}

interface Props {
    items: ResourceItem[];
}

const { items } = Astro.props;

function isExternal(href: string) {
    return href.startsWith("http://") || href.startsWith("https://");
}
---

{
    items.length > 0 && (
        <section id="resources" class="mt-16 pt-7 border-t border-border">
            <h2 class="font-heading text-[1.375rem] font-bold tracking-[-0.02em] leading-[1.25] text-hero-text mb-4">
                Resources
            </h2>
            <ul class="list-none p-0 m-0 rounded-lg border border-border overflow-hidden">
                {items.map((item) => {
                    const external = isExternal(item.href);
                    return (
                        <li class="border-b border-border last:border-b-0">
                            <a
                                href={item.href}
                                target={external ? "_blank" : undefined}
                                rel={external ? "noopener noreferrer" : undefined}
                                class="group flex items-center gap-6 px-4 py-2 bg-white transition-colors hover:bg-section-alt no-underline"
                            >
                                <Icon
                                    name={item.icon ?? "lucide:link"}
                                    size={20}
                                    aria-hidden="true"
                                    class="flex-shrink-0 text-text-secondary opacity-50"
                                />
                                <div>
                                    <p class="inline-flex items-center gap-1 text-sm font-medium text-accent mb-0 group-hover:underline group-hover:underline-offset-[3px]">
                                        {item.label}
                                        {external && (
                                            <Icon
                                                name="lucide:external-link"
                                                size={11}
                                                aria-hidden="true"
                                                class="flex-shrink-0 opacity-60"
                                            />
                                        )}
                                    </p>
                                    {item.description && (
                                        <p class="text-xs leading-relaxed text-text-secondary mt-0.5 mb-0">
                                            {item.description}
                                        </p>
                                    )}
                                </div>
                            </a>
                        </li>
                    );
                })}
            </ul>
        </section>
    )
}
