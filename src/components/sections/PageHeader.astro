---
import Tag from "../ui/Tag.astro";
import Eyebrow from "../ui/Eyebrow.astro";
import Title from "../ui/Title.astro";
import Description from "../ui/Description.astro";
import {
    getPageStyles,
    type PageStyleType,
} from "../../config/styles/categoryStyles";

interface Props {
    eyebrow?: string;
    title: string;
    description?: string;
    intro?: string;
    tags?: string[];
    variant?: PageStyleType;
    headerGradient?: string;
    titleAccent?: string;
    gridRgb?: string;
    innerClass?: string;
}

const {
    eyebrow,
    title,
    description,
    intro,
    tags = [],
    variant = "default",
    headerGradient,
    titleAccent,
    gridRgb,
    innerClass = "max-w-5xl mx-auto px-6 py-6",
} = Astro.props;

const pageStyle = getPageStyles(variant);
const resolvedGradient = headerGradient ?? pageStyle.headerGradient;
const resolvedAccent = titleAccent ?? pageStyle.titleAccent;
const resolvedRgb = gridRgb ?? pageStyle.gridRgb;
---

<!-- Full-width editorial header -->
<div
    class={`w-full pt-28 pb-14 md:pt-32 md:pb-12 px-6 border-b border-border ${resolvedGradient} relative`}
>
    <!-- Grid pattern overlay: sits on top of the gradient, below the text -->
    <div
        class="absolute inset-0 pointer-events-none select-none"
        aria-hidden="true"
        style={`background-image:
      linear-gradient(rgba(${resolvedRgb}, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(${resolvedRgb}, 0.1) 1px, transparent 1px);
    background-size: 28px 28px;
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      transparent 20%,
      rgba(0, 0, 0, 0.35) 65%,
      black 100%
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      transparent 20%,
      rgba(0, 0, 0, 0.35) 65%,
      black 100%
    );`}
    >
    </div>

    <div class={`relative ${innerClass}`}>
        <slot name="breadcrumb" />

        {eyebrow && <Eyebrow>{eyebrow}</Eyebrow>}

        <Title accentClass={resolvedAccent} class="mb-4">{title}</Title>

        {description && <Description class="mb-3">{description}</Description>}

        {
            intro && (
                <p class="text-text-secondary text-base leading-relaxed">
                    {intro}
                </p>
            )
        }

        <slot name="meta" />

        <slot name="tags">
            {
                tags.length > 0 && (
                    <div class="mt-6 flex flex-wrap gap-2">
                        {tags.map((tag) => (
                            <Tag label={tag} />
                        ))}
                    </div>
                )
            }
        </slot>

        <slot name="after" />
    </div>
</div>
