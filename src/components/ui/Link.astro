---
interface Props {
    href: string;
    class?: string;
    arrow?: "auto" | "forward" | "back" | "none";
    external?: boolean;
}

const {
    href,
    class: className,
    arrow = "auto",
    external: externalProp,
} = Astro.props;

const isMailto = href.startsWith("mailto:");
const isExternal =
    externalProp !== undefined
        ? externalProp
        : href.startsWith("http://") || href.startsWith("https://");

const shouldShowArrow = arrow !== "none" && !(arrow === "auto" && isMailto);

const arrowSymbol = !shouldShowArrow
    ? null
    : arrow === "back"
      ? "←"
      : arrow === "forward"
        ? "→"
        : isExternal
          ? "↗"
          : "→";

const baseClasses =
    "underline-offset-4 transition-opacity hover:opacity-60 hover:underline";

// gap lives on the inner span so the <a> stays plain inline,
// preserving text-align utilities (e.g. sm:text-right) on the caller
const innerClasses = `inline-flex items-center${arrow !== "none" ? " gap-1" : ""}`;

const classes = [baseClasses, className].filter(Boolean).join(" ");

const safeAttrs =
    isExternal && !isMailto
        ? { target: "_blank", rel: "noopener noreferrer" }
        : {};
---

<a href={href} class={classes} {...safeAttrs}>
    <span class={innerClasses}>
        {
            arrow === "back" && arrowSymbol && (
                <span aria-hidden="true" class="shrink-0 opacity-70 text-[0.7em]">
                    {arrowSymbol}
                </span>
            )
        }
        <slot />
        {
            arrow !== "back" && arrowSymbol && (
                <span aria-hidden="true" class="shrink-0 opacity-70 text-[0.7em]">
                    {arrowSymbol}
                </span>
            )
        }
    </span>
</a>
