---
interface Props {
    href: string;
    class?: string;
    arrow?: "auto" | "forward" | "back" | "none";
    external?: boolean;
}

const {
    href,
    class: className,
    arrow = "auto",
    external: externalProp,
} = Astro.props;

const isMailto = href.startsWith("mailto:");
const isExternal =
    externalProp !== undefined
        ? externalProp
        : href.startsWith("http://") || href.startsWith("https://");

const shouldShowArrow = arrow !== "none" && !(arrow === "auto" && isMailto);

const arrowSymbol = !shouldShowArrow
    ? null
    : arrow === "back"
      ? "←"
      : arrow === "forward"
        ? "→"
        : isExternal
          ? "↗"
          : "→";

// hover:underline goes on the inner span via group-hover because text-decoration
// does not render through an inline-flex boundary from a parent element
const baseClasses =
    "group underline-offset-4 transition-opacity hover:opacity-60 font-medium";

// arrow="none" → plain inline with accent color; arrows → flex row for symbol alignment
const displayClasses =
    arrow === "none" ? "inline" : "inline-flex items-center gap-1";
const toneClasses = arrow === "none" ? "text-accent" : "";

const classes = [baseClasses, toneClasses, className].filter(Boolean).join(" ");

const safeAttrs =
    isExternal && !isMailto
        ? { target: "_blank", rel: "noopener noreferrer" }
        : {};
---

<a href={href} class={classes} {...safeAttrs}>
    <span class={displayClasses}>
        {
            arrow === "back" && arrowSymbol && (
                <span
                    aria-hidden="true"
                    class="shrink-0 opacity-70 text-[0.7em]"
                >
                    {arrowSymbol}
                </span>
            )
        }
        <span class="group-hover:underline"><slot /></span>
        {
            arrow !== "back" && arrowSymbol && (
                <span
                    aria-hidden="true"
                    class="shrink-0 opacity-70 text-[0.7em]"
                >
                    {arrowSymbol}
                </span>
            )
        }
    </span>
</a>
