---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<span
  class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-3.5 py-1.5 text-sm font-medium leading-none text-slate-600 transition hover:bg-slate-100 hover:text-slate-900"
>
  {label}
</span>
