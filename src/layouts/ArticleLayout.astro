---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  readingTime?: string;
}

const { title, description, date, tags = [], readingTime } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const isoDate = date.toISOString().split('T')[0];
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="pt-20 pb-12 border-b border-border" style="background-color: var(--color-hero-bg);">
      <div class="max-w-2xl mx-auto px-6">
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-sm mb-8 transition-colors"
          style="color: var(--color-text-secondary);"
        >
          <span aria-hidden="true">←</span>
          Home
        </a>

        <h1
          class="font-heading text-[2rem] md:text-[2.5rem] font-bold tracking-[-0.03em] leading-[1.1] mb-4"
          style="color: var(--color-hero-text);"
        >
          {title}
        </h1>

        <p class="text-lg leading-relaxed mb-6" style="color: var(--color-text-secondary);">
          {description}
        </p>

        <div
          class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm"
          style="color: var(--color-text-secondary);"
        >
          <time datetime={isoDate}>{formattedDate}</time>
          {readingTime && (
            <>
              <span aria-hidden="true">·</span>
              <span>{readingTime}</span>
            </>
          )}
        </div>

        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {tags.map(tag => (
              <span
                class="text-xs font-medium tracking-wide px-3 py-1 rounded-full border"
                style="color: var(--color-text-secondary); background-color: var(--color-section-alt); border-color: var(--color-border);"
              >
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="py-14 px-6">
      <div class="max-w-2xl mx-auto article-body">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
