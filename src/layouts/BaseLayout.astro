---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import { site } from "../config/content/site";

interface Props {
    title?: string;
    description?: string;
}

const { title = site.title, description = site.description } = Astro.props;

const pageTitle =
    title === site.title
        ? `${site.name} — ${title}`
        : `${title} — ${site.name}`;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description} />
        <meta name="generator" content={Astro.generator} />
        <title>{pageTitle}</title>
        <link rel="icon" type="image/svg+xml" href={site.favicon.svg} />
        <link
            rel="icon"
            type="image/png"
            sizes="96x96"
            href={site.favicon.png96}
        />
        <link rel="shortcut icon" href={site.favicon.ico} />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href={site.favicon.appleTouchIcon}
        />
        <link rel="manifest" href={site.favicon.manifest} />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
    </head>
    <body class="font-sans">
        <a
            href="#main-content"
            class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 z-[60] px-4 py-2 bg-accent text-white text-sm font-medium rounded-md"
        >
            Skip to main content
        </a>
        <Header />
        <main id="main-content" tabindex="-1">
            <slot />
        </main>
        <Footer />
    </body>
</html>
