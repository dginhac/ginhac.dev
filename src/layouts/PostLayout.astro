---
import BaseLayout from "./BaseLayout.astro";
import type { ImageMetadata, MarkdownHeading } from "astro";
import { Image } from "astro:assets";
import TypeBadge from "../components/ui/TypeBadge.astro";
import { formatPostDate } from "../utils/posts/dateUtils";
import TableOfContents from "../components/post/TableOfContents.astro";
import RelatedPosts from "../components/post/RelatedPosts.astro";
import ResourceList from "../components/post/ResourceList.astro";
import Link from "../components/ui/Link.astro";
import type { CollectionEntry } from "astro:content";
import { getCategoryStyles } from "../config/styles/categoryStyles";

interface Props {
    title: string;
    description: string;
    date: Date;
    updated?: Date;
    type?: string;
    tags?: string[];
    readingTime?: string;
    featuredImageSrc?: ImageMetadata;
    featuredImageAlt?: string;
    headings?: MarkdownHeading[];
    relatedPosts?: CollectionEntry<"posts">[];
    eyebrow?: string;
    resources?: { label: string; href: string; description?: string }[];
}

const {
    title,
    description,
    date,
    updated,
    type,
    tags = [],
    readingTime,
    featuredImageSrc,
    featuredImageAlt,
    headings = [],
    relatedPosts = [],
    eyebrow,
    resources = [],
} = Astro.props;

const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
const showToc = tocHeadings.length >= 3;

// Inject a synthetic "Related posts" heading into the TOC when the section exists.
// The TableOfContents END_SECTIONS set will automatically place the divider before it.
const allTocHeadings: MarkdownHeading[] = [
    ...tocHeadings,
    ...(resources.length > 0
        ? [{ depth: 2, slug: "resources", text: "Resources" }]
        : []),
    ...(relatedPosts.length > 0
        ? [{ depth: 2, slug: "related-posts", text: "Related posts" }]
        : []),
];

const formattedDate = formatPostDate(date);
const isoDate = date.toISOString().split("T")[0];

const showUpdated = updated && updated.getTime() !== date.getTime();
const formattedUpdated = showUpdated ? formatPostDate(updated) : null;
const isoUpdated = showUpdated ? updated.toISOString().split("T")[0] : null;

const typeLabel = type?.toUpperCase();
const typeStyles = getCategoryStyles(typeLabel);

// When TOC is shown, use the same outer container as the body so the left edge
// aligns with the article column, while the header still spans the full width.
const headerInnerClass = showToc
    ? "max-w-5xl mx-auto"
    : "max-w-[52rem] mx-auto";
---

<BaseLayout title={title} description={description}>
    <article id="top">
        <!-- Full-width editorial header -->
        <div
            class={`pt-28 pb-14 md:pt-32 md:pb-12 px-6 ${typeStyles.headerGradient}`}
        >
            <div class={headerInnerClass}>
                <!-- Back link -->
                <Link
                    href="/posts"
                    arrow="back"
                    class="text-text-secondary text-sm mb-8 transition-opacity hover:opacity-60"
                >
                    All content
                </Link>

                <!-- Type label -->
                {
                    typeLabel && (
                        <div class="my-8">
                            <TypeBadge
                                type={typeLabel}
                                href={`/posts?type=${typeLabel}`}
                            />
                        </div>
                    )
                }

                <!-- Eyebrow -->
                {
                    eyebrow && (
                        <p class="text-xs font-medium tracking-[0.08em] uppercase mb-2 text-text-secondary">
                            {eyebrow}
                        </p>
                    )
                }

                <!-- Title -->
                <h1
                    class="font-heading text-3xl md:text-[2.5rem] font-bold tracking-[-0.02em] leading-[1.2] mb-6 text-hero-text"
                >
                    <span class={`${typeStyles.titleAccent} font-extrabold`}
                        >/</span
                    >
                    {title}
                </h1>

                <!-- Description -->
                <p
                    class="text-[1.0625rem] md:text-lg leading-[1.7] mb-4 text-text-primary"
                >
                    {description}
                </p>

                <!-- Meta: date then reading time -->
                <p class="text-sm text-slate-500 mb-8">
                    {
                        showUpdated ? (
                            <>
                                <span>
                                    Published{" "}
                                    <time datetime={isoDate}>
                                        {formattedDate}
                                    </time>
                                </span>
                                <span aria-hidden="true" class="opacity-40">
                                    ·
                                </span>
                                <span>
                                    Updated{" "}
                                    <time datetime={isoUpdated!}>
                                        {formattedUpdated}
                                    </time>
                                </span>
                            </>
                        ) : (
                            <time datetime={isoDate}>{formattedDate}</time>
                        )
                    }
                    {
                        readingTime && (
                            <>
                                <span aria-hidden="true" class="opacity-40">
                                    ·
                                </span>
                                <span>{readingTime}</span>
                            </>
                        )
                    }
                </p>
                <!-- Meta: tags  -->

                <div class="flex flex-col gap-y-5">
                    {
                        tags.length > 0 && (
                            <div class="flex flex-col gap-1.5">
                                <span class="text-xs font-medium uppercase tracking-[0.08em] text-text-secondary mb-2">
                                    Topics
                                </span>
                                <div class="flex flex-wrap gap-2">
                                    {tags.map((tag) => (
                                        <a
                                            href={`/posts?tag=${encodeURIComponent(tag)}`}
                                            class="inline-flex items-center rounded-full border border-border bg-section-alt px-2.5 py-1 text-xs font-medium text-text-secondary transition-colors hover:bg-footer-bg hover:text-text-primary"
                                        >
                                            {tag}
                                        </a>
                                    ))}
                                </div>
                            </div>
                        )
                    }
                </div>
            </div>
        </div>

        <!-- Lead image — only in single-column layout (aligns with max-w-[52rem] header) -->
        {
            !showToc && featuredImageSrc && (
                <div class="px-6 py-10 bg-site-bg">
                    <div class="max-w-[52rem] mx-auto">
                        <div class="rounded-xl overflow-hidden border aspect-[16/9] border-color-border">
                            <Image
                                src={featuredImageSrc}
                                alt={featuredImageAlt ?? ""}
                                class="w-full h-full object-cover"
                                widths={[800, 1200]}
                                sizes="(min-width: 900px) 832px, 100vw"
                            />
                        </div>
                    </div>
                </div>
            )
        }

        <!-- Post body -->
        <div
            class="px-6 pb-24"
            style={!showToc && featuredImageSrc ? "" : "padding-top: 3.5rem;"}
        >
            {
                showToc ? (
                    <div class="max-w-5xl mx-auto flex gap-14">
                        <div class="min-w-0 flex-1">
                            {featuredImageSrc && (
                                <div class="mb-10 rounded-xl overflow-hidden border aspect-[16/9] border-border">
                                    <Image
                                        src={featuredImageSrc}
                                        alt={featuredImageAlt ?? ""}
                                        class="w-full h-full object-cover"
                                        widths={[800, 1200]}
                                        sizes="(min-width: 900px) 700px, 100vw"
                                    />
                                </div>
                            )}
                            <div class="post-body">
                                <slot />
                            </div>
                            <ResourceList items={resources} />
                            <RelatedPosts posts={relatedPosts} />
                        </div>
                        <aside class="hidden xl:block w-[220px] shrink-0 pt-1">
                            <TableOfContents headings={allTocHeadings} />
                        </aside>
                    </div>
                ) : (
                    <div class="max-w-2xl mx-auto">
                        <div class="post-body">
                            <slot />
                        </div>
                        <ResourceList items={resources} />
                        <RelatedPosts posts={relatedPosts} />
                    </div>
                )
            }
        </div>
    </article>
</BaseLayout>
