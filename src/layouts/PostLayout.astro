---
import BaseLayout from "./BaseLayout.astro";
import type { ImageMetadata, MarkdownHeading } from "astro";
import { Image } from "astro:assets";
import TypeBadge from "../components/TypeBadge.astro";
import TableOfContents from "../components/TableOfContents.astro";

interface Props {
    title: string;
    description: string;
    date: Date;
    type?: string;
    tags?: string[];
    readingTime?: string;
    featuredImageSrc?: ImageMetadata;
    featuredImageAlt?: string;
    headings?: MarkdownHeading[];
}

const {
    title,
    description,
    date,
    type,
    tags = [],
    readingTime,
    featuredImageSrc,
    featuredImageAlt,
    headings = [],
} = Astro.props;

const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
const showToc = tocHeadings.length >= 3;

const formattedDate = date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});

const isoDate = date.toISOString().split("T")[0];

const typeLabel = type?.toUpperCase();
---

<BaseLayout title={title} description={description}>
    <article>
        <!-- Full-width editorial header -->
        <div
            class="pt-28 pb-14 md:pt-32 md:pb-18 px-6"
            style="background-color: var(--color-section-alt);"
        >
            <div class="max-w-[52rem] mx-auto">
                <!-- Back link -->
                <a
                    href="/posts"
                    class="inline-flex items-center gap-1.5 text-sm mb-8 transition-opacity hover:opacity-60"
                    style="color: var(--color-text-secondary);"
                >
                    <span aria-hidden="true">←</span>
                    All content
                </a>

                <!-- Type label -->
                {
                    typeLabel && (
                        <div class="mb-5">
                            <TypeBadge type={typeLabel} />
                        </div>
                    )
                }

                <!-- Title -->
                <h1
                    class="font-heading text-3xl md:text-[2.75rem] font-bold tracking-[-0.03em] leading-[1.08] mb-5"
                    style="color: var(--color-hero-text);"
                >
                    {title}
                </h1>

                <!-- Description -->
                <p
                    class="text-[1.0625rem] md:text-lg leading-[1.7] mb-8 max-w-[44rem]"
                    style="color: #475569;"
                >
                    {description}
                </p>

                <!-- Meta: tags then date · reading time -->
                <div class="flex flex-col gap-y-5">
                    {
                        tags.length > 0 && (
                            <div class="flex flex-wrap gap-2">
                                {tags.map((tag) => (
                                    <span
                                        class="text-xs font-medium px-2.5 py-0.5 rounded-full border"
                                        style="color: #2563EB; background-color: #EAF3FB; border-color: #C7DEF0;"
                                    >
                                        {tag}
                                    </span>
                                ))}
                            </div>
                        )
                    }

                    <div
                        class="flex items-center gap-x-2 text-sm"
                        style="color: var(--color-text-secondary);"
                    >
                        <time datetime={isoDate}>{formattedDate}</time>
                        {
                            readingTime && (
                                <>
                                    <span aria-hidden="true" class="opacity-40">
                                        ·
                                    </span>
                                    <span>{readingTime}</span>
                                </>
                            )
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Lead image (opt-in via showFeaturedImage: true) -->
        {
            featuredImageSrc && (
                <div
                    class="px-6 py-10"
                    style="background-color: var(--color-site-bg);"
                >
                    <div class="max-w-[52rem] mx-auto">
                        <div
                            class="rounded-xl overflow-hidden border aspect-[16/9]"
                            style="border-color: var(--color-border);"
                        >
                            <Image
                                src={featuredImageSrc}
                                alt={featuredImageAlt ?? ""}
                                class="w-full h-full object-cover"
                                widths={[800, 1200]}
                                sizes="(min-width: 900px) 832px, 100vw"
                            />
                        </div>
                    </div>
                </div>
            )
        }

        <!-- Post body -->
        <div
            class="px-6 pb-24"
            style={featuredImageSrc ? "" : "padding-top: 3.5rem;"}
        >
            {showToc ? (
                <div class="max-w-5xl mx-auto flex gap-14">
                    <div class="min-w-0 flex-1 post-body">
                        <slot />
                    </div>
                    <aside class="hidden xl:block w-[220px] shrink-0 pt-1">
                        <TableOfContents headings={tocHeadings} />
                    </aside>
                </div>
            ) : (
                <div class="max-w-2xl mx-auto post-body">
                    <slot />
                </div>
            )}
        </div>
    </article>
</BaseLayout>
