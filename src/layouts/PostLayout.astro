---
import BaseLayout from "./BaseLayout.astro";
import type { ImageMetadata, MarkdownHeading } from "astro";
import { Image } from "astro:assets";
import TypeBadge from "../components/TypeBadge.astro";
import TableOfContents from "../components/TableOfContents.astro";
import RelatedPosts from "../components/RelatedPosts.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
    title: string;
    description: string;
    date: Date;
    type?: string;
    tags?: string[];
    readingTime?: string;
    featuredImageSrc?: ImageMetadata;
    featuredImageAlt?: string;
    headings?: MarkdownHeading[];
    relatedPosts?: CollectionEntry<"posts">[];
}

const {
    title,
    description,
    date,
    type,
    tags = [],
    readingTime,
    featuredImageSrc,
    featuredImageAlt,
    headings = [],
    relatedPosts = [],
} = Astro.props;

const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
const showToc = tocHeadings.length >= 3;

// Inject a synthetic "Related posts" heading into the TOC when the section exists.
// The TableOfContents END_SECTIONS set will automatically place the divider before it.
const allTocHeadings: MarkdownHeading[] = [
    ...tocHeadings,
    ...(relatedPosts.length > 0
        ? [{ depth: 2, slug: "related-posts", text: "Related posts" }]
        : []),
];

const formattedDate = date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});

const isoDate = date.toISOString().split("T")[0];

const typeLabel = type?.toUpperCase();

// When TOC is shown, use the same outer container as the body so the left edge
// aligns with the article column, while the header still spans the full width.
const headerInnerClass = showToc
    ? "max-w-5xl mx-auto"
    : "max-w-[52rem] mx-auto";
---

<BaseLayout title={title} description={description}>
    <article id="top">
        <!-- Full-width editorial header -->
        <div
            class="pt-28 pb-14 md:pt-32 md:pb-18 px-6"
            style="background-color: var(--color-section-alt);"
        >
            <div class={headerInnerClass}>
                <!-- Back link -->
                <a
                    href="/posts"
                    class="inline-flex items-center gap-1.5 text-sm mb-8 transition-opacity hover:opacity-60"
                    style="color: var(--color-text-secondary);"
                >
                    <span aria-hidden="true">←</span>
                    All content
                </a>

                <!-- Type label -->
                {
                    typeLabel && (
                        <div class="mb-5">
                            <TypeBadge type={typeLabel} />
                        </div>
                    )
                }

                <!-- Title -->
                <h1
                    class="font-heading text-3xl md:text-[2.75rem] font-bold tracking-[-0.03em] leading-[1.08] mb-5"
                    style="color: var(--color-hero-text);"
                >
                    {title}
                </h1>

                <!-- Description -->
                <p
                    class="text-[1.0625rem] md:text-lg leading-[1.7] mb-8"
                    style="color: #475569;"
                >
                    {description}
                </p>

                <!-- Meta: tags then date · reading time -->
                <div class="flex flex-col gap-y-5">
                    {
                        tags.length > 0 && (
                            <div class="flex flex-wrap gap-2">
                                {tags.map((tag) => (
                                    <span
                                        class="text-xs font-medium px-2.5 py-0.5 rounded-full border"
                                        style="color: #2563EB; background-color: #EAF3FB; border-color: #C7DEF0;"
                                    >
                                        {tag}
                                    </span>
                                ))}
                            </div>
                        )
                    }

                    <div
                        class="flex items-center gap-x-2 text-sm"
                        style="color: var(--color-text-secondary);"
                    >
                        <time datetime={isoDate}>{formattedDate}</time>
                        {
                            readingTime && (
                                <>
                                    <span aria-hidden="true" class="opacity-40">
                                        ·
                                    </span>
                                    <span>{readingTime}</span>
                                </>
                            )
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Lead image — only in single-column layout (aligns with max-w-[52rem] header) -->
        {
            !showToc && featuredImageSrc && (
                <div
                    class="px-6 py-10"
                    style="background-color: var(--color-site-bg);"
                >
                    <div class="max-w-[52rem] mx-auto">
                        <div
                            class="rounded-xl overflow-hidden border aspect-[16/9]"
                            style="border-color: var(--color-border);"
                        >
                            <Image
                                src={featuredImageSrc}
                                alt={featuredImageAlt ?? ""}
                                class="w-full h-full object-cover"
                                widths={[800, 1200]}
                                sizes="(min-width: 900px) 832px, 100vw"
                            />
                        </div>
                    </div>
                </div>
            )
        }

        <!-- Post body -->
        <div
            class="px-6 pb-24"
            style={!showToc && featuredImageSrc ? "" : "padding-top: 3.5rem;"}
        >
            {showToc ? (
                <div class="max-w-5xl mx-auto flex gap-14">
                    <div class="min-w-0 flex-1">
                        {featuredImageSrc && (
                            <div
                                class="mb-10 rounded-xl overflow-hidden border aspect-[16/9]"
                                style="border-color: var(--color-border);"
                            >
                                <Image
                                    src={featuredImageSrc}
                                    alt={featuredImageAlt ?? ""}
                                    class="w-full h-full object-cover"
                                    widths={[800, 1200]}
                                    sizes="(min-width: 900px) 700px, 100vw"
                                />
                            </div>
                        )}
                        <div class="post-body">
                            <slot />
                        </div>
                        <RelatedPosts posts={relatedPosts} />
                    </div>
                    <aside class="hidden xl:block w-[220px] shrink-0 pt-1">
                        <TableOfContents headings={allTocHeadings} />
                    </aside>
                </div>
            ) : (
                <div class="max-w-2xl mx-auto">
                    <div class="post-body">
                        <slot />
                    </div>
                    <RelatedPosts posts={relatedPosts} />
                </div>
            )}
        </div>
    </article>
</BaseLayout>
