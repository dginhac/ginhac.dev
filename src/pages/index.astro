---
import { getCollection } from "astro:content";
import type { ImageMetadata } from "astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeHero from "../components/home/HomeHero.astro";
import FeaturedSection from "../components/home/FeaturedSection.astro";
import BioSection from "../components/home/BioSection.astro";
import { homeContent } from "../config/home";
import type { FeaturedItemType } from "../config/home";

const postImages = import.meta.glob<{ default: ImageMetadata }>(
    "/src/content/posts/**/*.{webp,jpg,jpeg,png}"
);

const allPosts = await getCollection("posts");
const featuredItems = await Promise.all(
    allPosts
        .filter((p) => p.data.featured && !p.data.draft)
        .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
        .slice(0, 4)
        .map(async (p) => {
            let featuredImage: ImageMetadata | undefined;
            if (p.data.featuredImage) {
                const key = `/src/content/posts/${p.id}/${p.data.featuredImage}`;
                if (postImages[key]) {
                    featuredImage = (await postImages[key]()).default;
                }
            }
            return {
                type: (p.data.type ?? "INSIGHT").toUpperCase() as FeaturedItemType,
                title: p.data.title,
                description: p.data.description,
                href: `/posts/${p.id}`,
                featuredImage,
                featuredImageAlt: p.data.featuredImageAlt,
            };
        })
);
---

<BaseLayout title={homeContent.meta.title} description={homeContent.meta.description}>
    <HomeHero hero={homeContent.hero} />
    <FeaturedSection featured={{ ...homeContent.featured, items: featuredItems }} />
    <BioSection bio={homeContent.bio} />
</BaseLayout>
