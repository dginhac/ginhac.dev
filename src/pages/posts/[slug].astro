---
import { getCollection, render } from "astro:content";
import type { ImageMetadata } from "astro";
import PostLayout from "../../layouts/PostLayout.astro";
import { getRelatedPosts } from "../../utils/relatedPosts";

export async function getStaticPaths() {
    const posts = await getCollection("posts");
    return posts.map((entry) => ({
        params: { slug: entry.id },
        props: { entry, allPosts: posts },
    }));
}

const { entry, allPosts } = Astro.props;
const relatedPosts = getRelatedPosts(entry, allPosts);
const { Content, headings } = await render(entry);

let featuredImageSrc: ImageMetadata | undefined;
if (entry.data.showFeaturedImage && entry.data.featuredImage) {
    const postImages = import.meta.glob<{ default: ImageMetadata }>(
        "/src/assets/posts/**/*.{webp,jpg,jpeg,png}"
    );
    const key = `/src/assets/posts/${entry.id}/${entry.data.featuredImage}`;
    if (postImages[key]) {
        featuredImageSrc = (await postImages[key]()).default;
    }
}
---

<PostLayout
    title={entry.data.title}
    description={entry.data.description}
    date={entry.data.date}
    type={entry.data.type}
    tags={entry.data.tags}
    readingTime={entry.data.readingTime}
    featuredImageSrc={featuredImageSrc}
    featuredImageAlt={entry.data.featuredImageAlt}
    headings={headings}
    relatedPosts={relatedPosts}
    eyebrow={entry.data.eyebrow}
>
    <Content />
</PostLayout>
