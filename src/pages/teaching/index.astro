---
import { getCollection } from "astro:content";
import type { ImageMetadata } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import AcademicCard from "../../components/cards/AcademicCard.astro";
import CompactAcademicCard from "../../components/cards/CompactAcademicCard.astro";
import Tag from "../../components/ui/Tag.astro";
import Link from "../../components/ui/Link.astro";
import Eyebrow from "../../components/ui/Eyebrow.astro";
import { teachingConfig } from "../../config/content/teaching";
import { getPageStyles } from "../../config/styles/categoryStyles";
import { getPostSlug } from "../../utils/posts/slugUtils";
import { getEffectivePostDate } from "../../utils/posts/dateUtils";

const styles = getPageStyles("teaching");

const { meta, eyebrow, title, description, intro, tags, sections, contact } =
    teachingConfig;

const postImages = import.meta.glob<{ default: ImageMetadata }>(
    "/src/content/posts/**/*.{webp,jpg,jpeg,png}",
);

const allPosts = await getCollection("posts", (post) => !post.data.draft);

const teachingCourses = allPosts
    .filter(
        (post) => post.data.type === "teaching" && post.data.kind === "course",
    )
    .sort((a, b) => getEffectivePostDate(b).getTime() - getEffectivePostDate(a).getTime());

const currentCourses = await Promise.all(
    teachingCourses
        .filter((c) => c.data.status === "current")
        .map(async (post) => {
            let image: ImageMetadata | undefined;
            if (post.data.featuredImage) {
                const key = `/src/content/posts/${post.id}/${post.data.featuredImage}`;
                if (postImages[key]) {
                    image = (await postImages[key]()).default;
                }
            }
            return { post, image };
        }),
);

const pastCourses = teachingCourses.filter((c) => c.data.status === "past");
---

<BaseLayout title={meta.title} description={meta.description}>
    <!-- Page header -->
    <div class={`w-full border-b border-border ${styles.headerGradient}`}>
        <div class="max-w-5xl mx-auto px-6 py-12 sm:py-16">
            <!-- Eyebrow -->
            <Eyebrow class="mt-8 mb-2">{eyebrow}</Eyebrow>

            <h1
                class="font-heading text-3xl md:text-[2.5rem] font-bold text-hero-text tracking-[-0.02em] leading-[1.2] mb-4"
            >
                <span class={`${styles.titleAccent} font-extrabold`}>/</span>
                {title}
            </h1>
            <p
                class="text-text-secondary text-base sm:text-lg leading-relaxed mb-3"
            >
                {description}
            </p>
            <p class="text-text-secondary text-base leading-relaxed">
                {intro}
            </p>
            <div class="mt-6 flex flex-wrap gap-2">
                {tags.map((tag) => <Tag label={tag} />)}
            </div>
        </div>
    </div>

    <!-- Current modules -->
    <section
        class="max-w-5xl mx-auto px-6 py-12 md:py-16"
        aria-labelledby="current-heading"
    >
        <div class="mb-8">
            <p
                class="text-xs font-medium tracking-[0.08em] uppercase text-text-secondary mb-2"
            >
                Current
            </p>
            <h2
                id="current-heading"
                class="font-heading text-2xl md:text-[1.875rem] font-bold tracking-[-0.02em] leading-[1.2] text-text-primary mb-2"
            >
                <span class="text-accent-soft font-extrabold">/</span>
                {sections.current.title}
            </h2>
            {
                sections.current.description && (
                    <p class="text-text-secondary text-base leading-[1.65]">
                        {sections.current.description}
                    </p>
                )
            }
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {
                currentCourses.map(({ post, image }) => (
                    <AcademicCard
                        title={post.data.title}
                        description={post.data.description}
                        href={`/posts/${getPostSlug(post.id)}`}
                        image={image}
                        period={post.data.period}
                        level={post.data.level}
                        institution={post.data.institution}
                        volume={post.data.volume}
                        role={post.data.role}
                        tags={post.data.tags}
                        linkLabel="View course →"
                    />
                ))
            }
        </div>
    </section>

    <!-- Previous modules -->
    {
        pastCourses.length > 0 && (
            <section
                class="bg-section-alt border-t border-border"
                aria-labelledby="previous-heading"
            >
                <div class="max-w-5xl mx-auto px-6 py-12 md:py-16">
                    <div class="mb-8">
                        <p class="text-xs font-medium tracking-[0.08em] uppercase text-text-secondary mb-2">
                            Previous
                        </p>
                        <h2
                            id="previous-heading"
                            class="font-heading text-2xl md:text-[1.875rem] font-bold tracking-[-0.02em] leading-[1.2] text-text-primary mb-2"
                        >
                            <span class="text-accent-soft font-extrabold">
                                /
                            </span>
                            {sections.previous.title}
                        </h2>
                        {sections.previous.description && (
                            <p class="text-text-secondary text-base leading-[1.65]">
                                {sections.previous.description}
                            </p>
                        )}
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                        {pastCourses.map((post) => (
                            <CompactAcademicCard
                                title={post.data.title}
                                description={post.data.description}
                                href={`/posts/${getPostSlug(post.id)}`}
                                period={post.data.period}
                                level={post.data.level}
                                institution={post.data.institution}
                                volume={post.data.volume}
                                role={post.data.role}
                                tags={post.data.tags}
                                linkLabel="View course →"
                            />
                        ))}
                    </div>
                </div>
            </section>
        )
    }

    <!-- Contact -->
    <div class="border-t border-border">
        <div class="max-w-5xl mx-auto px-6 py-10">
            <p class="text-text-secondary text-sm">
                {contact.text}
                {" "}
                <Link href={contact.href} class="link" arrow="none"
                    >{contact.linkLabel}</Link
                >.
            </p>
        </div>
    </div>
</BaseLayout>
